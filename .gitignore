# ── Data & corpora (never commit LibriSpeech / features) ──
# NOTE: leading slash anchors these to the repo ROOT so they do NOT also match
# the source package src/dcasr/data/ or any src/**/features/ module dir.
/data/
/LibriSpeech/
*.wav
*.flac
*.ark
*.scp
/features/
/manifests/*.json
!/manifests/.gitkeep

# ── Checkpoints, logs, experiment outputs ──
experiments/*/
!experiments/.gitkeep
checkpoints/
*.ckpt
*.pt
*.pth
runs/
tb_logs/
wandb/
lightning_logs/
*.log

# ── Forced-alignment artifacts (MFA) ──
alignments/
*.TextGrid

# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Runlog (local append-only project history — source of truth, never committed) ──
/runlog.md

# ── Editors / OS ──
.vscode/
.idea/
.DS_Store
*.swp

# ── Secrets ──
.env
*.key
